# ==================== Energy Cache ====================
_parser_cache: Dict[str, 'OrcaParser'] = {}
_mtime_cache: Dict[str, float] = {}

def get_cached_parser(file_path: str) -> 'OrcaParser':
    """Return a cached OrcaParser, re-reading only if file has changed."""
    try:
        mtime = os.path.getmtime(file_path)
    except OSError:
        return OrcaParser(file_path)
    if file_path in _parser_cache and _mtime_cache.get(file_path) == mtime:
        return _parser_cache[file_path]
    parser = OrcaParser(file_path)
    _parser_cache[file_path] = parser
    _mtime_cache[file_path] = mtime
    return parser

# ==================== Parser ====================
class OrcaParser:
    def __init__(self, file_path):
        self.file_path = file_path
        self.filename = os.path.basename(file_path)
        self.content = None
        self._read_file()

    def _read_file(self):
        for encoding in ['utf-8', 'latin-1', 'cp1252']:
            try:
                with open(self.file_path, 'r', encoding=encoding) as f:
                    self.content = f.read()
                return
            except UnicodeDecodeError:
                continue
        try:
            with open(self.file_path, 'r', encoding='utf-8', errors='replace') as f:
                self.content = f.read()
        except Exception as e:
            raise ValueError(f"Cannot read file {self.filename}: {e}")

    def get_energy(self, energy_type="gibbs"):
        patterns = {
            'gibbs': r"Final Gibbs free energy\s*\.*\s*([-\d\.]+)",
            'enthalpy': r"Total Enthalpy\s*\.*\s*([-\d\.]+)",
            'electronic': r"FINAL SINGLE POINT ENERGY\s+([-\d\.]+)"
        }
        pattern = patterns.get(energy_type.lower())
        if not pattern:
            return None
        matches = re.findall(pattern, self.content)
        if matches:
            try:
                return float(matches[-1])
            except ValueError:
                return None
        return None

    def get_all_thermo(self):
        results = {}
        types = {
            'Electronic': r"FINAL SINGLE POINT ENERGY\s+([-\d\.]+)",
            'Enthalpy':   r"Total Enthalpy\s*\.*\s*([-\d\.]+)",
            'Gibbs':      r"Final Gibbs free energy\s*\.*\s*([-\d\.]+)"
        }
        for k, p in types.items():
            matches = re.findall(p, self.content)
            results[k] = float(matches[-1]) if matches else None
        return results

# ==================== Undo Manager ====================
class UndoManager:
    """Snapshot-based undo/redo for the staging list."""
    def __init__(self, max_depth=50):
        self._undo_stack: List[Any] = []
        self._redo_stack: List[Any] = []
        self._max = max_depth

    def push(self, staging_list: List['PlotItem']):
        """Save a deep copy of the current state before mutation."""
        self._undo_stack.append(copy.deepcopy(staging_list))
        if len(self._undo_stack) > self._max:
            self._undo_stack.pop(0)
        self._redo_stack.clear()

    def undo(self, current: List['PlotItem']) -> Optional[List['PlotItem']]:
        if not self._undo_stack:
            return None
        self._redo_stack.append(copy.deepcopy(current))
        return self._undo_stack.pop()

    def redo(self, current: List['PlotItem']) -> Optional[List['PlotItem']]:
        if not self._redo_stack:
            return None
        self._undo_stack.append(copy.deepcopy(current))
        return self._redo_stack.pop()

    def can_undo(self) -> bool:
        return len(self._undo_stack) > 0

    def can_redo(self) -> bool:
        return len(self._redo_stack) > 0

# ==================== Threading Workers ====================
class FolderLoader(QThread):
    finished = Signal(dict)
    error = Signal(str)
    progress = Signal(int)
    files_found = Signal(int)

    def __init__(self, folder_path):
        super().__init__()
        self.folder_path = folder_path
        self._stop = False

    def stop(self):
        self._stop = True

    def run(self):
        try:
            all_files = []
            total_found = 0
            for root_dir, _, filenames in os.walk(self.folder_path):
                if self._stop:
                    return
                out_files = [f for f in filenames if f.lower().endswith('.out')]
                if out_files:
                    for f in out_files:
                        full_path = os.path.join(root_dir, f)
                        all_files.append(full_path)
                        total_found += 1
                        self.files_found.emit(total_found)

            if self._stop:
                return

            total = len(all_files)
            if total == 0:
                self.finished.emit({'path': self.folder_path, 'files': []})
                return

            files = []
            for i, full_path in enumerate(all_files):
                if self._stop:
                    return
                rel_path = os.path.relpath(full_path, self.folder_path)
                files.append((rel_path, full_path))
                self.progress.emit(i + 1)

            files.sort(key=lambda x: [
                int(c) if c.isdigit() else c.lower()
                for c in re.split('([0-9]+)', x[0])
            ])

            self.finished.emit({'path': self.folder_path, 'files': files})
        except Exception as e:
            self.error.emit(str(e))

