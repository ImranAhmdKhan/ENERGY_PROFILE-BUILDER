    # ------------------------------------------------------------------
    def _iter_items_with_x(self):
        is_overlay = self.check_overlay.isChecked()
        curr_x = 0
        for _f_path, group in groupby(enumerate(self.plot_staging_list), key=lambda x: x[1].folder_path):
            items = list(group)
            for i, (orig_idx, it) in enumerate(items):
                lx = i if is_overlay else (curr_x + i)
                yield orig_idx, it, lx
            if not is_overlay:
                curr_x += len(items)

    # --------------------- Dragging fix --------------------------
    def _get_display_y(self, item):
        """Return the Y‑coordinate (in data coordinates) of the bar for a given item,
           using the same reference method as the plot."""
        e_type = self.energy_type_combo.currentText().lower()
        conv = self._conv_factor()
        ref_mode = self.zero_ref_combo.currentText()
        val = self.calculate_state_energy(item, e_type)
        if val is None:
            return None
        if ref_mode == "Per Pathway (First State)":
            # Find the first state in this folder (by order in staging list)
            folder = item.folder_path
            first_val = None
            for it in self.plot_staging_list:
                if it.folder_path == folder:
                    first_val = self.calculate_state_energy(it, e_type)
                    break
            if first_val is None:
                return None
            return (val - first_val) * conv
        else:
            global_ref = self.get_reference_energy()
            if global_ref is None:
                return None
            return (val - global_ref) * conv

    def on_press(self, event):
        if not self.check_interactive.isChecked() or event.inaxes != self.ax:
            return
        if event.xdata is None or event.ydata is None:
            return

        min_dist = self.pick_threshold
        found_idx = None
        found_type = None

        for orig_idx, it, lx in self._iter_items_with_x():
            y = self._get_display_y(it)
            if y is None:
                continue

            dist = np.sqrt((event.xdata - (lx + it.label_offset[0])) ** 2 +
                           (event.ydata - (y + it.label_offset[1])) ** 2)
            if dist < min_dist:
                min_dist = dist
                found_idx = orig_idx
                found_type = 'label'

            if (abs(event.xdata - lx) < 0.3 and abs(event.ydata - y) < 0.5):
                found_idx = orig_idx
                found_type = 'state'

        self.dragging_idx = found_idx
        self.dragging_type = found_type
        if found_idx is not None:
            self.undo_mgr.push(self.plot_staging_list)
            name = self.plot_staging_list[found_idx].custom_name or self.plot_staging_list[found_idx].display_name
            self.statusBar().showMessage(f"Dragging {found_type}: {name}", 2000)

    def on_motion(self, event):
        if self.dragging_idx is None or event.inaxes != self.ax:
            return
        if event.xdata is None or event.ydata is None:
            return

        it = self.plot_staging_list[self.dragging_idx]

        for orig_idx, item, lx in self._iter_items_with_x():
            if orig_idx != self.dragging_idx:
                continue
            y = self._get_display_y(item)
            if y is None:
                return
            if self.dragging_type == 'label':
                it.label_offset[0] = event.xdata - lx
                it.label_offset[1] = event.ydata - y
            elif self.dragging_type == 'state':
                it.label_offset[0] = event.xdata - lx
            # Use draw_idle for smoother drag (deferred redraw)
            self.update_plot()
            self.canvas.draw_idle()
            return

    def on_release(self, event):
        if self.dragging_idx is not None:
            self._dirty = True
            self.statusBar().showMessage("Drag completed", 2000)
        self.dragging_idx = None
        self.dragging_type = None

    def on_pick(self, event):
        pass

    # ==================== Logic ====================
    def _conv_factor(self):
        if self.btn_kcal.isChecked():
            return 627.509
        if self.btn_kj.isChecked():
            return 2625.5
        return 27.2114

    def calculate_state_energy(self, item, energy_type):
        """Calculate the total energy for a PlotItem using cached parsers.
        For CSV-imported items (with item.energy set and no file_data), use the stored energy directly."""
        # Handle CSV-imported data with direct energy values
        if item.energy is not None and not item.file_data:
            return item.energy
        total = 0.0
        for path, multiplier in item.file_data:
            val = get_cached_parser(path).get_energy(energy_type)
            if val is None:
                return None
            total += val * multiplier
        return total

    def get_reference_energy(self):
        """Returns a single reference energy for the global reference mode.
           For per‑pathway mode, returns None (signals that reference is computed per folder)."""
        e_type = self.energy_type_combo.currentText().lower()
        ref_text = self.zero_ref_combo.currentText()
        if ref_text == "Per Pathway (First State)":
            return None
        if ref_text == "Minimum (Global)":
            ens = [self.calculate_state_energy(it, e_type) for it in self.plot_staging_list]
            valid = [e for e in ens if e is not None]
            return np.min(valid) if valid else None
        # Otherwise it's a specific state name
        for it in self.plot_staging_list:
            name = it.custom_name if it.custom_name else it.display_name
            if name == ref_text:
                return self.calculate_state_energy(it, e_type)
        return None

