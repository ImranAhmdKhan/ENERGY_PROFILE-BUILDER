    def add_folder_dialog(self):
        path = QFileDialog.getExistingDirectory(self, "Select ORCA Results Folder")
        if not path or path in self.folders:
            return

        progress = QProgressDialog("Scanning folder...", "Cancel", 0, 0, self)
        progress.setWindowTitle("Loading Folder")
        progress.setWindowModality(Qt.WindowModal)
        progress.setMinimumDuration(0)
        progress.setAutoClose(False)
        progress.setAutoReset(False)
        progress.setLabelText("Scanning folder... (0 files found)")
        progress.show()

        loader = FolderLoader(path)

        # Connect signals
        loader.files_found.connect(lambda count: progress.setLabelText(
            f"Scanning folder... ({count} files found)"))
        loader.finished.connect(lambda data: self._on_folder_loaded(data, progress, loader))
        loader.error.connect(lambda msg: self._on_folder_error(msg, progress, loader))

        def on_cancel():
            loader.stop()
            progress.close()
        progress.canceled.connect(on_cancel)

        # Clean up loader when done
        loader.finished.connect(loader.deleteLater)
        loader.error.connect(loader.deleteLater)

        loader.start()

    def _on_folder_loaded(self, data, progress, loader):
        progress.close()
        self.on_folder_loaded(data)

    def _on_folder_error(self, msg, progress, loader):
        progress.close()
        QMessageBox.critical(self, "Error", f"Failed to load folder: {msg}")

