    def open_label_editor(self):
        row = self.staging_list.currentRow()
        if row == -1:
            QMessageBox.warning(self, "No Selection", "Please select a state to edit.")
            return
        self.undo_mgr.push(self.plot_staging_list)
        dlg = LabelEditorDialog(self.plot_staging_list[row], self)
        if dlg.exec():
            values = dlg.get_values()
            for key, value in values.items():
                setattr(self.plot_staging_list[row], key, value)
            self._dirty = True
            self.sync_sidebar_list()
            self.update_plot()

    def duplicate_selected_state(self):
        row = self.staging_list.currentRow()
        if row == -1:
            return
        self.undo_mgr.push(self.plot_staging_list)
        original = self.plot_staging_list[row]
        duplicate = copy.deepcopy(original)
        duplicate.custom_name = f"{duplicate.custom_name or duplicate.display_name} (copy)"
        duplicate.label_offset = [original.label_offset[0] + 0.1, original.label_offset[1] + 0.1]
        self.plot_staging_list.insert(row + 1, duplicate)
        self._dirty = True
        self.sync_sidebar_list()
        self.update_plot()

