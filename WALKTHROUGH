    def add_to_staging(self, folder_path, combined=False):
        folder_data = self.folders[folder_path]
        lst = folder_data['list_widget']
        sel = lst.selectedItems()

        if not sel:
            QMessageBox.information(self, "No Selection", "Please select files to add.")
            return

        if combined:
            paths = [i.data(Qt.UserRole) for i in sel]
            dlg = MultipliersDialog(paths, self)
            if dlg.exec():
                f_data = dlg.get_values()
                disp = " + ".join([f"{m}*{os.path.basename(p)[:8]}" for p, m in f_data])
                self.plot_staging_list.append(PlotItem(file_data=f_data, display_name=disp, folder_path=folder_path))
                li = QListWidgetItem(disp)
                li.setForeground(QColor(folder_data['color']))
                self.staging_list.addItem(li)
        else:
            for i in sel:
                full = i.data(Qt.UserRole)
                disp = f"[{os.path.basename(folder_path)}] {i.text()}"
                self.plot_staging_list.append(PlotItem(file_data=[(full, 1.0)], display_name=disp, folder_path=folder_path))
                li = QListWidgetItem(disp)
                li.setForeground(QColor(folder_data['color']))
                self.staging_list.addItem(li)

        self.filter_staging_list()
        self.update_plot()
        self.statusBar().showMessage(f"Added {len(sel)} item(s) to staging", 3000)

